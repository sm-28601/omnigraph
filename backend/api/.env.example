# Server runtime
PORT=8080
DATA_DIR=../../data/processed
NODE_ENV=development
API_DATA_SOURCE=csv

# API security
# Set true in non-local environments
API_AUTH_ENABLED=false

# Comma-separated token:role pairs.
# Roles: viewer, analyst, admin
# Example: API_KEYS=viewer-token:viewer,analyst-token:analyst,admin-token:admin
API_KEYS=

# PostgreSQL connection (used when API_DATA_SOURCE=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omnigraph
POSTGRES_USER=omnigraph
POSTGRES_PASSWORD=omnigraph
